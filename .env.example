# ─────────────────────────────────────────────────────────────────────────────
# Profile (kingofyadav.in) — Environment Variables Reference
# Copy to .env for local dev. On Vercel: Settings → Environment Variables.
# NEVER commit .env (it is gitignored). Only commit .env.example.
# Generate secrets with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# ── Server (local dev only — not used on Vercel) ──────────────────────────────
PORT=3000
CORS_ORIGIN=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# Railway PostgreSQL or Vercel Postgres connection string.
DATABASE_URL=postgresql://user:password@host:port/dbname
# Set to "false" only for local dev without TLS. Always "true" in production.
DATABASE_SSL=true

# ── Auth / OTP ────────────────────────────────────────────────────────────────
# JWT signing secret. Must be 32+ characters.
# Generate: openssl rand -hex 32
AUTH_JWT_SECRET=
# MSG91 credentials — https://msg91.com → SMS → Templates
MSG91_AUTHKEY=your_msg91_authkey
MSG91_TEMPLATE_ID=your_msg91_otp_template_id
MSG91_OTP_LENGTH=6
MSG91_OTP_EXPIRY_MINUTES=5
# Optional Railway OTP microservice base URL.
# Leave blank if handling OTP entirely via MSG91 directly.
OTP_API_BASE=

# ── HI API (private dashboard endpoints) ──────────────────────────────────────
# Static bearer token gating /api/hi/* endpoints.
# Must match HI_API_KEY in work_station/.env.
# Generate: openssl rand -hex 32
HI_API_KEY=

# ── Jarvis AI Backend ─────────────────────────────────────────────────────────
# Public URL of the Jarvis API server (work_station).
JARVIS_API_BASE=https://jarvis.kingofyadav.in
# Alternate env name accepted by jarvis-chat.js (falls back to JARVIS_API_BASE).
JARVIS_BACKEND_URL=
# Bridge auth secret sent as: Authorization: Bearer <secret>
# Must match JARVIS_BRIDGE_SECRET in work_station/.env.
# Generate: openssl rand -hex 32
JARVIS_BRIDGE_SECRET=

# ── OpenAI (live-class endpoint) ──────────────────────────────────────────────
# Required for /api/live-class AI responses. Leave blank to disable AI responses.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Leave blank to use api.openai.com (default). Set for Azure OpenAI or proxies.
OPENAI_BASE_URL=

# ── Live Class ────────────────────────────────────────────────────────────────
# Bearer token protecting /api/live-class and /api/push endpoints.
LIVE_CLASS_TOKEN=

# ── Push Notifications (VAPID) ────────────────────────────────────────────────
# Generate keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:circle.onelife@gmail.com
