# ─────────────────────────────────────────────────────────────
# Profile (kingofyadav.in) — Environment Variables
# Copy to .env and fill in real values before running locally.
# On Vercel: set these in the project's Environment Variables UI.
# ─────────────────────────────────────────────────────────────

# ── Server (local dev only) ────────────────────────────────────
PORT=5050
CORS_ORIGIN=http://localhost:3000

# ── Database ───────────────────────────────────────────────────
# Vercel Postgres (or any pg-compatible connection string)
DATABASE_URL=postgres://user:password@host:5432/dbname
# Set to "false" only for local dev without TLS
DATABASE_SSL=true

# ── Auth / OTP ──────────────────────────────────────────────────
AUTH_JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
MSG91_AUTHKEY=your_msg91_authkey
MSG91_TEMPLATE_ID=your_msg91_otp_template_id
MSG91_OTP_LENGTH=6
MSG91_OTP_EXPIRY_MINUTES=5
OTP_API_BASE=https://your-railway-service.up.railway.app/api

# ── HI API (private dashboard endpoints) ──────────────────────
# Static bearer token that gates /api/hi/* endpoints.
# Must match the value stored in the browser's sessionStorage after login.
HI_API_KEY=replace_with_a_long_random_secret_min_32_chars

# ── Jarvis AI Backend ──────────────────────────────────────────
# Public URL of the Jarvis API (work_station).
# When set, /api/jarvis-chat proxies requests to Jarvis instead of using the fallback.
JARVIS_API_BASE=https://jarvis.kingofyadav.in
# Alternative env name (also accepted by jarvis-chat.js)
JARVIS_BACKEND_URL=
# Shared secret for the Profile → Jarvis proxy bridge.
# Must match JARVIS_BRIDGE_SECRET in work_station/.env.
# Profile sends this as Authorization: Bearer on every proxied chat request.
JARVIS_BRIDGE_SECRET=

# ── Push Notifications ─────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:circle.onelife@gmail.com
