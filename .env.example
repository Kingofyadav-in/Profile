# ══════════════════════════════════════════════════════
#  kingofyadav.in — Environment Variables
#  Copy this file to .env and fill in real values.
#  Never commit .env to version control.
# ══════════════════════════════════════════════════════

# ── Live Class Board ──────────────────────────────────
# Secret token that authenticates teacher commands sent
# to POST /api/live-class. Set any strong random string.
# On Vercel: Dashboard → Project → Settings → Environment Variables
# Locally:   export LIVE_CLASS_TOKEN="your-secret-here"
LIVE_CLASS_TOKEN=

# ── Jarvis AI Backend ─────────────────────────────────
# API key for the Jarvis AI service (Claude-powered backend).
# Used by the HI Assistant chat panel on /pages/personal.html
# when calling POST /api/jarvis-chat.
# On Vercel: same as above
# Locally:   the live-server proxies to http://127.0.0.1:5050
JARVIS_API_KEY=

# ── Optional: Live Class endpoint override ────────────
# Override the board.js endpoint when posting from a remote machine.
# Defaults to http://127.0.0.1:8787/api/live-class
# LIVE_CLASS_ENDPOINT=https://kingofyadav.in/api/live-class

# ── Optional: Server Port (local dev only) ────────────
# PORT=8787
