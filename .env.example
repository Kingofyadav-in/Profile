# Profile (kingofyadav.in) environment reference
#
# Local:
#   cp .env.example .env
#   npm start
#
# Deployment:
#   Do not upload this file as-is. Add the real values in Vercel, Railway, or
#   GitHub repository secrets/variables. Keep .env and .env.local uncommitted.
#
# Secret generation:
#   openssl rand -hex 32

# Server
# The OTP server defaults to 5050, which matches the browser auth fallback.
PORT=5050
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5050,http://127.0.0.1:5050
NODE_ENV=development

# Database
# Railway PostgreSQL, Vercel Postgres, Neon, Supabase, or local Postgres.
DATABASE_URL=postgresql://user:password@host:5432/database
# Use "false" only for a local Postgres server without TLS.
DATABASE_SSL=true

# Auth / OTP
AUTH_JWT_SECRET=
MSG91_AUTHKEY=
MSG91_TEMPLATE_ID=
MSG91_OTP_LENGTH=6
MSG91_OTP_EXPIRY_MINUTES=5
# Optional upstream OTP service. Leave blank when running server/otp-server.js.
OTP_API_BASE=
# Backward-compatible alias accepted by api/auth/_proxy.js.
AUTH_API_BASE=

# HI API
# Bearer token for /api/hi/* and /api/wallet/*.
HI_API_KEY=

# Jarvis AI backend
JARVIS_API_BASE=https://jarvis.kingofyadav.in
# Backward-compatible alias accepted by api/jarvis-chat.js.
JARVIS_BACKEND_URL=
JARVIS_BRIDGE_SECRET=

# OpenAI live-class endpoint
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Leave blank for https://api.openai.com.
OPENAI_BASE_URL=

# Live Class / Push
LIVE_CLASS_TOKEN=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:kingofyadav.in@gmail.com
